# Frontend — copy to ".env" then npm run build (Vite bakes this in at build time)

# Local dev (contact API on same PC):
VITE_CONTACT_API_URL=http://127.0.0.1:8787/api/contact

# Production — same VPS as the website: use a relative path if Nginx proxies /api → Node (recommended)
# VITE_CONTACT_API_URL=/api/contact

# Production — or full URL if the API is on another host/port:
# VITE_CONTACT_API_URL=http://121.40.103.137/api/contact

# --- server/index.mjs environment (on the VPS, not in Vite) ---
# PORT=8787
# If the browser talks to /api on the same origin, CORS can stay loose; still set for clarity:
# CORS_ORIGIN=http://121.40.103.137,http://localhost:5173
#
# Optional Gmail SMTP (App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=cassiezhangsmile@gmail.com
# SMTP_PASS=your-app-password
# MAIL_TO=cassiezhangsmile@gmail.com
# MAIL_FROM="CassieHome Tools" <cassiezhangsmile@gmail.com>

# --- Nginx on 121.40.103.137 (example): static site + proxy API ---
# root /var/www/cassiehometools/dist;
# location /api/ {
#   proxy_pass http://127.0.0.1:8787/api/;
#   proxy_http_version 1.1;
#   proxy_set_header Host $host;
#   proxy_set_header X-Real-IP $remote_addr;
# }
